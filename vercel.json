{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/config",
      "dest": "/api/config.js"
    },
    {
      "src": "/api/news",
      "dest": "/api/news.js"
    },
    {
      "src": "/api/newsapi",
      "dest": "/api/newsapi.js"
    },
    {
      "src": "/api/rss",
      "dest": "/api/rss.js"
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/results",
      "dest": "/api/results.js"
    },
    {
      "src": "/api/eci-news",
      "dest": "/api/eci-news.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}