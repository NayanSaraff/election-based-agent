{
  "version": 2,
  "routes": [
    {
      "src": "/api/config",
      "dest": "/api/config.js"
    },
    {
      "src": "/api/news",
      "dest": "/api/news.js"
    },
    {
      "src": "/api/newsapi",
      "dest": "/api/newsapi.js"
    },
    {
      "src": "/api/rss",
      "dest": "/api/rss.js"
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/results",
      "dest": "/api/results.js"
    },
    {
      "src": "/api/eci-news",
      "dest": "/api/eci-news.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}